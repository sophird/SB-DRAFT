# Copy to `.env` and fill in values. Never commit `.env`.

# --- Supabase (required) ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Server ---
PORT=4000
# IANA timezone for system-admin audit log "Date" column (matches wall clock in that zone; DB stores timestamptz in UTC).
# Use UTC if you want to match raw UTC strings in SQL. Default below matches Philippines.
# AUDIT_LOG_DISPLAY_TIMEZONE=Asia/Manila
# Comma-separated allowed browser origins for CORS, or omit to allow any in dev.
# Add the URL where you open resident/*.html (e.g. npx serve) so /faq/chat works from the browser.
# CLIENT_ORIGIN=http://localhost:3000,http://localhost:5500

# --- Groq (optional: FAQ chat, admin analytics decision insight on reports-analytics.html) ---
# Console: https://console.groq.com/keys — create an API key and paste it here.
GROQ_API_KEY=
# Any model Groq exposes on the OpenAI-compatible API, e.g. llama-3.3-70b-versatile.
# Larger Llama checkpoints often follow Tagalog instructions better than small/fast models.
GROQ_MODEL=
# System-admin audit log descriptions: set to 0 to skip Groq one-sentence rewrites (uses raw text).
# AUDIT_LOG_GROQ_SUMMARY=1
# Optional: items per Groq request when summarizing audit rows (default 18, max 32).
# AUDIT_GROQ_SUMMARY_CHUNK_SIZE=18
